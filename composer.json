{
    "name": "eliel-elie/laravel-connection-guard",
    "description": "Project Laravel database connections with configurable guards such as read-only mode, dangerous SQL prevention and custom validation rules.",
    "type": "library",
	"keywords": [
        "laravel",
        "database",
        "connection",
        "guard",
        "read-only",
        "oracle",
        "mysql",
        "postgresql",
        "sqlserver",
        "sqlite"
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Elielelie\\ConnectionGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elielelie\\Connection\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Eliel Ferreira",
            "email": "eliel_elie@hotmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
	"require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^2.0 || ^3.0",
        "pestphp/pest-plugin-laravel": "^2.0 || ^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elielelie\\ConnectionGuard\\ConnectionGuardServiceProvider"
            ],
            "aliases": {
                "ConnectionGuard": "Elielelie\\ConnectionGuard\\\\Facades\\ConnectionGuard"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
